{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/recurring-reminders",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/daily-digest",
      "schedule": "0 1 * * *"
    }
  ]
}
